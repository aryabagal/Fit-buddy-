import logging
from tenacity import retry, wait_exponential, stop_after_attempt, retry_if_exception_type
import google.generativeai as genai

# Configure logging to see when it retries
logging.basicConfig(level=logging.INFO)

# Define which errors to retry on (429 is the key one)
def is_rate_limit_error(exception):
    return "429" in str(exception)

@retry(
    wait=wait_exponential(multiplier=1, min=4, max=60), # Starts at 4s, doubles up to 60s
    stop=stop_after_attempt(5),                         # Stop after 5 tries
    retry=retry_if_exception_type(Exception)            # Or a specific Gemini error class
)
async def call_gemini_safe(prompt):
    model = genai.GenerativeModel('gemini-2.0-flash')
    response = model.generate_content(prompt)
    return response.text

@app.post("/generate-workout")
async def generate_workout(user_data: dict):
    try:
        plan = await call_gemini_safe(f"Create a workout for {user_data['goal']}")
        return {"plan": plan}
    except Exception as e:
        return {"error": "Server is busy, please try again later.", "details": str(e)}